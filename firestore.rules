rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    function signedIn() {
      return request.auth != null;
    }

    function isSelf(uid) {
      return signedIn() && request.auth.uid == uid;
    }

    function userDoc(uid) {
      return get(/databases/$(database)/documents/users/$(uid));
    }

    function isPublicProfile(uid) {
      return userDoc(uid).data.publicProfile != false;
    }

    function isFollowing(a, b) {
      return userDoc(a).data.followingUsers is list
        && userDoc(a).data.followingUsers.hasAny([b]);
    }

    function isMutualFollow(a, b) {
      return isFollowing(a, b) && isFollowing(b, a);
    }

    function sharesCommunity(a, b) {
      return userDoc(a).data.followingCommunities is list
        && userDoc(b).data.followingCommunities is list
        && userDoc(a).data.followingCommunities.hasAny(userDoc(b).data.followingCommunities);
    }

    function communityDoc(communityId) {
      return get(/databases/$(database)/documents/communities/$(communityId));
    }

    function isCommunityAdminById(communityId) {
      return signedIn()
        && communityDoc(communityId).exists()
        && (
          communityDoc(communityId).data.ownerId == request.auth.uid
          || communityDoc(communityId).data.modIds.hasAny([request.auth.uid])
        );
    }

    function isCommunityAdminFromResource() {
      return signedIn()
        && (
          resource.data.ownerId == request.auth.uid
          || resource.data.modIds.hasAny([request.auth.uid])
        );
    }

    function communityJoinKeysOnly() {
      return request.resource.data.diff(resource.data).changedKeys().hasOnly([
        "memberIds",
        "onlineMemberIds",
        "membersCount",
        "onlineCount",
        "updatedAt"
      ]);
    }

    function isPublicOrInviteCommunity() {
      return (resource.data.privacy == "public" || resource.data.privacy == "invite");
    }

    function isSelfJoin() {
      return signedIn()
        && isPublicOrInviteCommunity()
        && !resource.data.memberIds.hasAny([request.auth.uid])
        && request.resource.data.memberIds.hasAny([request.auth.uid])
        && request.resource.data.memberIds.hasAll(resource.data.memberIds)
        && request.resource.data.memberIds.size() == resource.data.memberIds.size() + 1;
    }

    function isSelfLeave() {
      return signedIn()
        && resource.data.memberIds.hasAny([request.auth.uid])
        && !request.resource.data.memberIds.hasAny([request.auth.uid])
        && resource.data.memberIds.hasAll(request.resource.data.memberIds)
        && request.resource.data.memberIds.size() + 1 == resource.data.memberIds.size();
    }

    match /users/{uid} {
      allow read: if signedIn();
      allow create: if isSelf(uid);
      allow update: if isSelf(uid);
      allow delete: if false;
    }

    match /communities/{communityId} {
      allow read: if signedIn();
      allow create: if signedIn()
        && request.resource.data.ownerId == request.auth.uid
        && request.resource.data.memberIds.hasAny([request.auth.uid])
        && request.resource.data.modIds.hasAny([request.auth.uid]);

      allow update: if signedIn() && (
        isCommunityAdminFromResource()
        || (
          !isCommunityAdminFromResource()
          && communityJoinKeysOnly()
          && (isSelfJoin() || isSelfLeave())
        )
      );
      allow delete: if isCommunityAdminFromResource();

      match /doubts/{doubtId} {
        allow read: if signedIn();
        allow create: if signedIn()
          && request.resource.data.authorId == request.auth.uid;
        allow update: if signedIn() && (
          resource.data.authorId == request.auth.uid
          || (
            request.resource.data.diff(resource.data).changedKeys().hasOnly([
              "answersCount",
              "lastAnsweredAt",
              "updatedAt",
              "acceptedAnswerId",
              "solvedAt",
              "solvedBy"
            ])
            && request.resource.data.answersCount >= resource.data.answersCount
          )
        );
        allow delete: if signedIn()
          && resource.data.authorId == request.auth.uid;

        match /answers/{answerId} {
          allow read: if signedIn();
          allow create: if signedIn()
            && request.resource.data.authorId == request.auth.uid;
          allow update: if signedIn()
            && resource.data.authorId == request.auth.uid;
          allow delete: if signedIn()
            && resource.data.authorId == request.auth.uid;
        }

      }

      match /polls/{pollId} {
        allow read: if signedIn();
        allow create: if signedIn()
          && request.resource.data.authorId == request.auth.uid;
        allow update: if signedIn()
          && resource.data.authorId == request.auth.uid;
        allow delete: if signedIn()
          && resource.data.authorId == request.auth.uid;

        match /responses/{responseId} {
          allow read: if signedIn();
          allow create: if signedIn()
            && request.resource.data.userId == request.auth.uid;
          allow update: if signedIn()
            && resource.data.userId == request.auth.uid;
          allow delete: if signedIn()
            && resource.data.userId == request.auth.uid;
        }
      }
    }

    // Allow collectionGroup reads for doubts across communities.
    match /{document=**}/doubts/{doubtId} {
      allow read: if signedIn();
    }

    match /posts/{postId} {
      allow read: if signedIn();
      allow create: if signedIn()
        && request.resource.data.authorId == request.auth.uid;

      allow update: if signedIn() && (
        resource.data.authorId == request.auth.uid
        || (
          request.resource.data.diff(resource.data).changedKeys().hasOnly(["likes", "likedBy", "reached20Rewarded", "trendingRewarded"])
          && request.resource.data.likedBy.hasAll(resource.data.likedBy)
          && request.resource.data.likes >= resource.data.likes
        )
      );

      allow delete: if signedIn() && (
        resource.data.authorId == request.auth.uid
        || isCommunityAdminById(resource.data.community)
      );

      match /comments/{commentId} {
        allow read: if signedIn();
        allow create: if signedIn()
          && request.resource.data.authorId == request.auth.uid;

        allow update: if signedIn() && (
          resource.data.authorId == request.auth.uid
          || (
            request.resource.data.diff(resource.data).changedKeys().hasOnly(["likes", "likedBy", "helpful", "helpfulMarkedBy"])
            && request.resource.data.likes >= resource.data.likes
          )
        );

        allow delete: if signedIn() && (
          resource.data.authorId == request.auth.uid
          || isCommunityAdminById(get(/databases/$(database)/documents/posts/$(postId)).data.community)
        );
      }
    }

    match /messages/{messageId} {
      allow read: if signedIn();
      allow create: if signedIn()
        && request.resource.data.senderId == request.auth.uid;
      allow update: if signedIn()
        && resource.data.senderId == request.auth.uid
        && request.resource.data.senderId == resource.data.senderId
        && request.resource.data.roomId == resource.data.roomId;
      allow delete: if signedIn()
        && resource.data.senderId == request.auth.uid;
    }

    match /dmThreads/{threadId} {
      allow read: if signedIn()
        && isPublicProfile(request.auth.uid)
        && resource.data.participantIds.hasAny([request.auth.uid]);

      allow create: if signedIn()
        && isPublicProfile(request.auth.uid)
        && request.resource.data.participantIds.size() == 2
        && request.resource.data.participantIds.hasAny([request.auth.uid])
        && request.resource.data.requesterId == request.auth.uid
        && request.resource.data.participantIds.hasAny([request.resource.data.recipientId])
        && request.resource.data.participantIds.hasAny([request.resource.data.requesterId])
        && isPublicProfile(request.resource.data.recipientId)
        && (
          (
            request.resource.data.status == "active"
            && isMutualFollow(request.resource.data.requesterId, request.resource.data.recipientId)
          )
          || (
            request.resource.data.status == "request"
            && sharesCommunity(request.resource.data.requesterId, request.resource.data.recipientId)
          )
          || (
            request.resource.data.status == "active"
            && request.resource.data.origin == "collab"
            && request.resource.data.collabListingId is string
            && get(/databases/$(database)/documents/collabListings/$(request.resource.data.collabListingId)).exists()
            && get(/databases/$(database)/documents/collabListings/$(request.resource.data.collabListingId)).data.authorId
              == request.resource.data.recipientId
          )
        );

      allow update: if signedIn()
        && isPublicProfile(request.auth.uid)
        && resource.data.participantIds.hasAny([request.auth.uid])
        && request.resource.data.participantIds == resource.data.participantIds
        && request.resource.data.requesterId == resource.data.requesterId
        && request.resource.data.recipientId == resource.data.recipientId
        && request.resource.data.createdAt == resource.data.createdAt
        && request.resource.data.diff(resource.data).changedKeys().hasOnly(["status", "updatedAt", "lastMessage", "origin", "collabListingId"])
        && (
          (
            resource.data.status == "request"
            && request.resource.data.status == "active"
            && (
              request.auth.uid == resource.data.recipientId
              || (
                request.resource.data.origin == "collab"
                && request.resource.data.collabListingId is string
                && get(/databases/$(database)/documents/collabListings/$(request.resource.data.collabListingId)).exists()
                && get(/databases/$(database)/documents/collabListings/$(request.resource.data.collabListingId)).data.authorId
                  == resource.data.recipientId
                && request.auth.uid == resource.data.requesterId
              )
            )
          )
          || (
            resource.data.status == request.resource.data.status
            && request.resource.data.origin == resource.data.origin
            && request.resource.data.collabListingId == resource.data.collabListingId
          )
        );

      allow delete: if signedIn()
        && isPublicProfile(request.auth.uid)
        && resource.data.participantIds.hasAny([request.auth.uid]);

      match /messages/{messageId} {
        allow read: if signedIn()
          && isPublicProfile(request.auth.uid)
          && get(/databases/$(database)/documents/dmThreads/$(threadId)).data.participantIds.hasAny([request.auth.uid]);

        allow create: if signedIn()
          && isPublicProfile(request.auth.uid)
          && request.resource.data.senderId == request.auth.uid
          && get(/databases/$(database)/documents/dmThreads/$(threadId)).data.participantIds.hasAny([request.auth.uid])
          && (
            get(/databases/$(database)/documents/dmThreads/$(threadId)).data.status == "active"
            || (
              get(/databases/$(database)/documents/dmThreads/$(threadId)).data.status == "request"
              && get(/databases/$(database)/documents/dmThreads/$(threadId)).data.requesterId == request.auth.uid
            )
          )
          && isPublicProfile(get(/databases/$(database)/documents/dmThreads/$(threadId)).data.participantIds[0])
          && isPublicProfile(get(/databases/$(database)/documents/dmThreads/$(threadId)).data.participantIds[1]);

        allow update: if signedIn()
          && isPublicProfile(request.auth.uid)
          && resource.data.senderId == request.auth.uid;

        allow delete: if signedIn()
          && isPublicProfile(request.auth.uid)
          && resource.data.senderId == request.auth.uid;
      }
    }

    match /mentorshipOffers/{offerId} {
      allow read: if signedIn();
      allow create: if signedIn()
        && request.resource.data.authorId == request.auth.uid;
      allow update: if signedIn()
        && resource.data.authorId == request.auth.uid;
      allow delete: if signedIn()
        && resource.data.authorId == request.auth.uid;
    }

    match /mentorshipRequests/{requestId} {
      allow read: if signedIn();
      allow create: if signedIn()
        && request.resource.data.authorId == request.auth.uid;
      allow update: if signedIn()
        && resource.data.authorId == request.auth.uid;
      allow delete: if signedIn()
        && resource.data.authorId == request.auth.uid;
    }

    match /users/{uid}/notifications/{notificationId} {
      allow read: if isSelf(uid);
      allow create: if isSelf(uid);
      allow update: if isSelf(uid);
      allow delete: if isSelf(uid);
    }

    match /collabListings/{listingId} {
      allow read: if signedIn();
      allow create: if signedIn()
        && request.resource.data.authorId == request.auth.uid;
      allow update: if signedIn()
        && resource.data.authorId == request.auth.uid;
      allow delete: if signedIn()
        && resource.data.authorId == request.auth.uid;
    }

    match /teamFinderListings/{listingId} {
      allow read: if signedIn();
      allow create: if signedIn()
        && request.resource.data.authorId == request.auth.uid;
      allow update: if signedIn()
        && resource.data.authorId == request.auth.uid;
      allow delete: if signedIn()
        && resource.data.authorId == request.auth.uid;
    }

    match /studyRooms/{roomId} {
      allow read: if signedIn();
      allow create: if signedIn();
      allow update: if signedIn();
      allow delete: if signedIn();

      match /messages/{messageId} {
        allow read: if signedIn();
        allow create: if signedIn();
        allow update: if signedIn();
        allow delete: if signedIn();
      }

      match /resources/{resourceId} {
        allow read: if signedIn();
        allow create: if signedIn();
        allow update: if signedIn();
        allow delete: if signedIn();
      }

      match /sessionLogs/{logId} {
        allow read: if signedIn();
        allow create: if signedIn();
        allow update: if signedIn();
        allow delete: if signedIn();
      }
    }
  }
}
